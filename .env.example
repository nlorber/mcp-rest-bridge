# Transport: "stdio" (default) or "http"
MCP_TRANSPORT=stdio

# HTTP transport settings
MCP_HTTP_PORT=3456

# Target API
API_BASE_URL=http://localhost:3100
API_USERNAME=admin
API_PASSWORD=admin123

# Logging
LOG_LEVEL=info

# Timeouts (ms)
HTTP_TIMEOUT_MS=30000
DEFAULT_TOOL_TIMEOUT_MS=60000

# Cache
CACHE_TTL_MS=300000

# Adversarial tests (optional)
ANTHROPIC_API_KEY=
